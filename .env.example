# Copy to `.env` and adjust. Defaults are safe for local development.

PORT=3000
NODE_ENV=development

# --- Database (matches docker-compose.yml) ---------------------------------
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_USER=ggi_user
DATABASE_PASSWORD=ggi_password
DATABASE_NAME=ggi_backend

# --- Schema management -----------------------------------------------------
# Migrations own the schema. Set DB_SYNCHRONIZE=true only for throwaway local DBs.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- Proof-of-possession (HMAC request signing) ----------------------------
REQUEST_SIGNATURE_SECRET=dev-request-signing-secret-123456

# --- Mock OIDC identity provider (JWT) -------------------------------------
# These MUST match scripts/signed-request.ps1.
OIDC_ISSUER=https://mock-idp.ggi.local/
OIDC_AUDIENCE=ggi-backend
OIDC_JWT_SECRET=dev-oidc-mock-signing-secret-change-me
OIDC_TOKEN_TTL_SECONDS=3600
OIDC_CLOCK_TOLERANCE_SECONDS=30

# --- Global request timeout ------------------------------------------------
REQUEST_TIMEOUT_MS=15000

# --- Rate limits (per rolling window) --------------------------------------
RATE_LIMIT_IP_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_DEFAULT_MAX=60
RATE_LIMIT_CHAT_MAX=10
RATE_LIMIT_SUBSCRIPTIONS_MAX=20
RATE_LIMIT_ADMIN_MAX=30

# --- Billing simulation ----------------------------------------------------
# Fraction of renewal charges that randomly fail (0..1). 0 = always succeed.
BILLING_PAYMENT_FAILURE_RATE=0.2
# Run the renewal job on an interval inside the server process.
BILLING_SCHEDULER_ENABLED=false
BILLING_SCHEDULER_INTERVAL_MS=3600000
